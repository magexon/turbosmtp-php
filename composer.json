{
    "name": "magexon/turbosmtp-php",
    "version": "1.0.0",
    "description": "TurboSMTP PHP SDK for sending emails, managing relays, suppressions, and email validation",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4 || ^8.0",
        "guzzlehttp/guzzle": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "TurboSMTP\\": "src/",
            "API_TurboSMTP_Invoker\\": "src/API.TurboSMTP/lib/",
            "API_TurboSMTP_Model\\": "src/API.TurboSMTP/lib/API_TurboSMTP_Model/",
            "API_TurboSMTP\\": "src/API.TurboSMTP/lib/API_TurboSMTP/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TurboSMTPTests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "turbosmtp",
        "email",
        "smtp",
        "mail",
        "api"
    ],
    "homepage": "https://turbosmtp.com",
    "support": {
        "issues": "https://github.com/turbosmtp/turboSMTP-php/issues"
    }
}
